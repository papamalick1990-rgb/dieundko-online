# Copiez ce fichier en ".env" (sans ".example") et remplissez les valeurs.
# Ne partagez JAMAIS votre fichier .env — il contient vos secrets.

# Port sur lequel le serveur écoute (la plupart des hébergeurs le définissent
# automatiquement — dans ce cas vous pouvez laisser cette ligne telle quelle)
PORT=3000

# Clé secrète utilisée pour signer les sessions de connexion (JWT).
# Générez une valeur aléatoire longue, par exemple avec :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=remplacez_ceci_par_une_longue_chaine_aleatoire

# Hachage bcrypt de votre mot de passe vendeur.
# Générez-le avec : npm run hash-password -- "VotreMotDePasse"
# Puis collez le résultat ici (jamais le mot de passe en clair).
ADMIN_PASSWORD_HASH=collez_ici_le_hachage_genere
